# ==========================================================
# 🌐 MultiMed Fusion - Environment Configuration Sample File
# ==========================================================
# This file defines the environment variables required
# to configure and run the MultiMed Fusion backend application.
# Rename this file to ".env" and update the placeholder values.
# ==========================================================

# -------------------------
# ⚙️ General App Settings
# -------------------------
DJANGO_ENV=development              # Django environment (development/production)
APP_ENV=development                 # Custom environment flag
SECRET_KEY=replace_with_secret      # Django secret key for cryptographic signing
JWT_SECRET=replace_with_jwt_secret  # Secret key for JWT token generation (djangorestframework-simplejwt)
APP_NAME=MultiMed-Fusion
APP_VERSION=1.2.0

# -------------------------
# 🗄️ Database Configuration
# -------------------------
# MongoDB (primary — for patient records, embeddings, AI summaries, audit logs)
MONGODB_URI=mongodb://user:pass@localhost:27017/multimed_fusion_db

# PostgreSQL (for structured relational data — user accounts, access control)
DATABASE_URL=postgresql://user:pass@localhost:5432/multimed_fusion_db

# -------------------------
# ☁️ File Storage (AWS S3)
# -------------------------
S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_REGION=us-east-1
ENABLE_FILE_VERSIONING=true         # Keep old versions of uploaded medical files
MAX_UPLOAD_SIZE_MB=200              # Maximum file size limit in MB

# -------------------------
# 🤖 AI Models / APIs
# -------------------------
HUGGINGFACE_API_KEY=hf_xxx          # Hugging Face API key for transformer models
OPENAI_API_KEY=sk-xxx               # OpenAI API key for LLM-based summarization
MODEL_ENDPOINT=http://localhost:8000/predict_summary  # Local model inference endpoint
DEFAULT_SUMMARY_LANGUAGE=en         # Default language for AI-generated summaries
ENABLE_CONFIDENCE_SCORES=true       # Attach confidence scores to AI responses
ENABLE_AI_SUMMARIZATION=true        # Toggle the RAG summarization pipeline on/off

# -------------------------
# 🎧 Audio Transcription
# -------------------------
TRANSCRIBE_API_KEY=your_transcription_service_key   # API key for speech-to-text service
ENABLE_AUDIO_TRANSCRIPTION=true     # Enable/disable audio note transcription pipeline

# -------------------------
# 🩻 DICOM Paths (Medical Imaging)
# -------------------------
DICOM_STORAGE_PATH=/data/dicom                      # Persistent storage path for DICOM files
DICOM_TEMP_PATH=/tmp/dicom_processing               # Temp path for DICOM anonymization processing
ENABLE_DICOM_PROCESSING=true        # Toggle DICOM anonymization and handling

# -------------------------
# ⚡ Background Tasks / Caching (Celery + Redis)
# -------------------------
REDIS_URL=redis://localhost:6379/0  # Redis URL used as Celery broker and cache backend
CACHE_EXPIRY=3600                   # Cache expiration time in seconds (1 hour)
ENABLE_ASYNC_TASKS=true             # Enable Celery background tasks (OCR, embedding, transcription)
ENABLE_CACHING=true                 # Enable Redis caching for repeated queries

# -------------------------
# 🔐 Security & Anonymization
# -------------------------
ENABLE_ANONYMIZATION=true           # Automatically strip PHI (Protected Health Information)
ANONYMIZATION_MODE=regex_spacy      # Anonymization engine: regex_spacy (default) or presidio
ENCRYPTION_ENABLED=true             # Encrypt sensitive fields at rest in the database

# -------------------------
# 🧩 Logging & Monitoring
# -------------------------
LOG_LEVEL=INFO                      # Logging level: DEBUG / INFO / WARNING / ERROR
ENABLE_ADMIN_MONITORING=true        # Expose /health and /metrics endpoints for monitoring
ENABLE_AUDIT_LOGS=true              # Log all user and system actions for HIPAA traceability
LOG_FILE_PATH=logs/app.log          # File path for application logs
ENABLE_ERROR_ALERTS=false           # Send alerts on failed API calls (set true in production)

# -------------------------
# 🖥️ Frontend / CORS Settings
# -------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000   # React frontend dev origins
FRONTEND_BASE_URL=http://localhost:3000

# -------------------------
# 📧 Email / Notifications
# -------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
ENABLE_EMAIL_NOTIFICATIONS=true     # Toggle email alerts for system events
NOTIFICATION_LANGUAGE=en            # Language for outgoing notification emails

# -------------------------
# 🧠 Developer & Debug
# -------------------------
DEBUG_MODE=true                     # Enable Django debug mode (set false in production)
ENABLE_TEST_DATA=true               # Load MongoDB seed data for local development
ENABLE_API_DOCS=true                # Enable Django REST Framework Swagger docs at /docs
